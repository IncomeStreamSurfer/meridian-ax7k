---
import Base from '../layouts/Base.astro';
import StorySection from '../components/StorySection.astro';
import FeaturedNotes from '../components/FeaturedNotes.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const siteUrl = Astro.site?.toString() || 'https://meridian-ax7k.vercel.app';

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Meridian',
  url: siteUrl,
  logo: `${siteUrl}favicon.svg`,
  description: 'A specialty coffee brand built for discerning drinkers who value traceable single-origin beans and the quiet ritual of a perfect cup.',
  foundingDate: '2025',
  slogan: 'Coffee at the crossroads of craft and origin.',
  sameAs: [],
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Meridian',
  url: siteUrl,
  description: 'Coffee at the crossroads of craft and origin.',
};
---

<Base
  title="Meridian | Specialty Coffee Coming Soon"
  description="Meridian is a specialty coffee brand rooted in craft and origin. Join the waitlist and be first to taste what we've been building."
  structuredData={[organizationLd, websiteLd]}
>

  <!-- HERO -->
  <section class="relative overflow-hidden grain">
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute -top-24 -right-24 w-[36rem] h-[36rem] rounded-full blur-3xl opacity-30" style="background: radial-gradient(closest-side, var(--color-amber), transparent 70%);"></div>
      <div class="absolute bottom-[-6rem] left-[-6rem] w-[28rem] h-[28rem] rounded-full blur-3xl opacity-20" style="background: radial-gradient(closest-side, var(--color-amber-dark), transparent 70%);"></div>
    </div>

    <div class="mx-auto max-w-7xl px-6 lg:px-10 pt-10 pb-24 lg:pt-16 lg:pb-36">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <div class="lg:col-span-7">
          <p class="marker text-xs tracking-[0.25em] uppercase muted mb-6">Coming soon · Roasting begins Spring</p>
          <h1 class="font-display text-[2.6rem] sm:text-6xl lg:text-7xl leading-[0.98] tracking-tight">
            Coffee at the
            <span class="italic text-[color:var(--color-amber)]">crossroads</span>
            of craft and origin.
          </h1>
          <p class="mt-8 max-w-xl text-lg leading-relaxed muted">
            Meridian is a specialty coffee brand in the making — single-origin beans, meticulous roasting, and the quiet ritual of a perfect cup. We're almost ready to pour. Join the waitlist to be first.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a href="#waitlist" class="inline-flex items-center gap-2 rounded-full bg-[color:var(--color-amber)] text-[color:var(--color-ink)] px-6 py-3 font-medium hover:bg-[color:var(--color-amber-dark)] hover:text-[color:var(--color-cream)] transition">
              Join the waitlist
              <span aria-hidden="true">→</span>
            </a>
            <a href="/about" class="inline-flex items-center gap-2 rounded-full border rule px-6 py-3 font-medium hover:text-[color:var(--color-amber)] transition">
              Read our story
            </a>
          </div>

          <dl class="mt-14 grid grid-cols-3 max-w-lg gap-6 text-sm">
            <div>
              <dt class="muted uppercase tracking-widest text-[10px]">Origin</dt>
              <dd class="font-display text-2xl mt-1">Single</dd>
            </div>
            <div>
              <dt class="muted uppercase tracking-widest text-[10px]">Roast</dt>
              <dd class="font-display text-2xl mt-1">Small batch</dd>
            </div>
            <div>
              <dt class="muted uppercase tracking-widest text-[10px]">Trade</dt>
              <dd class="font-display text-2xl mt-1">Direct</dd>
            </div>
          </dl>
        </div>

        <div class="lg:col-span-5 relative">
          <div class="relative aspect-[4/5] rounded-2xl overflow-hidden surface rule border shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1511920170033-f8396924c348?auto=format&fit=crop&w=1200&q=80"
              alt="A porcelain cup of specialty coffee sits on a linen cloth beside scattered single-origin beans"
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent pointer-events-none"></div>
            <div class="absolute left-5 bottom-5 text-[color:var(--color-cream)]">
              <p class="text-[10px] tracking-[0.3em] uppercase opacity-80">N° 001 · Ethiopia, Yirgacheffe</p>
              <p class="font-display text-2xl mt-1">Jasmine, bergamot, stone-fruit.</p>
            </div>
          </div>
          <div class="absolute -bottom-6 -left-6 hidden md:flex items-center gap-3 rule border rounded-full surface px-4 py-2 text-xs shadow-lg">
            <span class="w-2 h-2 rounded-full bg-[color:var(--color-amber)] animate-pulse"></span>
            <span class="muted">Green beans in transit</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Marquee ticker -->
    <div class="border-y rule overflow-hidden">
      <div class="flex whitespace-nowrap ticker py-4 font-display italic text-lg">
        <div class="flex items-center gap-12 pr-12">
          <span>Ethiopia · Yirgacheffe</span><span>·</span>
          <span>Colombia · Huila</span><span>·</span>
          <span>Guatemala · Huehuetenango</span><span>·</span>
          <span>Kenya · Nyeri</span><span>·</span>
          <span>Rwanda · Nyamasheke</span><span>·</span>
          <span>Costa Rica · Tarrazú</span><span>·</span>
        </div>
        <div class="flex items-center gap-12 pr-12" aria-hidden="true">
          <span>Ethiopia · Yirgacheffe</span><span>·</span>
          <span>Colombia · Huila</span><span>·</span>
          <span>Guatemala · Huehuetenango</span><span>·</span>
          <span>Kenya · Nyeri</span><span>·</span>
          <span>Rwanda · Nyamasheke</span><span>·</span>
          <span>Costa Rica · Tarrazú</span><span>·</span>
        </div>
      </div>
    </div>
  </section>

  <StorySection />
  <FeaturedNotes />
  <WaitlistForm />

</Base>
